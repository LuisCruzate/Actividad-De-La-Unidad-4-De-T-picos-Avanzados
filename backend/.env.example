# ================================================
# VARIABLES DE ENTORNO - PLATAFORMA SOSTENIBLE
# ================================================
# Copia este archivo a .env y completa los valores

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# BASE DE DATOS
# ============================================
# MongoDB local
MONGO_URI=mongodb://localhost:27017/productos_sostenibles

# O MongoDB Cloud (Atlas)
# MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/productos_sostenibles?retryWrites=true&w=majority

# ============================================
# AUTENTICACIÓN Y SEGURIDAD
# ============================================
# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=tu_clave_secreta_muy_segura_cambiar_en_produccion_12345
JWT_EXPIRY=24h

# ============================================
# CONTROL DE ACCESO (CORS)
# ============================================
# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000

# ============================================
# CORREO ELECTRÓNICO
# ============================================
# Para recuperación de contraseña y notificaciones
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu_contraseña_app_gmail
EMAIL_SERVICE=gmail

# Para usar con otro proveedor (ej: SendGrid)
# SENDGRID_API_KEY=tu_api_key

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# MÉTODOS DE PAGO
# ============================================
# Stripe (opcional)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLIC_KEY=pk_test_xxx

# PayPal (opcional)
# PAYPAL_CLIENT_ID=xxx
# PAYPAL_CLIENT_SECRET=xxx

# ============================================
# LOGGING Y MONITOREO
# ============================================
# Sentry (optional error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# CONFIGURACIÓN DE ARCHIVOS
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,gif,webp

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5

# ============================================
# API KEYS (si usas servicios externos)
# ============================================
# Geolocalización, mapas, etc
# GOOGLE_MAPS_API_KEY=xxx
